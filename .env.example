NOTION_TOKEN=ntn_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

GOOGLE_CLIENT_SECRET_FILE=./client_secret_your_oauth_client.json
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

APP_TIMEZONE=Europe/Moscow
SYNC_DEFAULT_EVENT_MINUTES=30
SYNC_MAX_PAGES=100
STATE_DB_PATH=./data/sync-state.sqlite3
# Optional durable state backends:
# STATE_DATABASE_URL=postgresql://user:password@host:5432/database
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# CLOUD_SQL_DATABASE=notion_gcal_sync
# CLOUD_SQL_USER=sync_user
# CLOUD_SQL_PASSWORD=your_cloud_sql_password
LOG_LEVEL=INFO

NOTION_PROP_TITLE=Name
NOTION_PROP_DATE=Date/time
